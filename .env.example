# =============================================================================
# FINDIVO — Environment Variables
# Copy this file to .env.local and fill in values after creating free accounts.
# NEVER commit .env.local to GitHub.
# =============================================================================

# --- Neon PostgreSQL (neon.tech) ---
# Dashboard → Project → Connection string → "Pooled connection"
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# --- Upstash Redis (upstash.com) ---
# Dashboard → your database → REST API tab
UPSTASH_REDIS_REST_URL=https://YOUR-INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# --- Resend Email (resend.com) ---
# Dashboard → API Keys → Create
RESEND_API_KEY=re_xxxxxxxxxxxx
# Use onboarding@resend.dev for testing; switch to your domain after verification
RESEND_FROM_EMAIL=Findivo <onboarding@resend.dev>

# --- Amazon Associates (affiliate-program.amazon.com) ---
# After approval: Account → Manage Your Tracking IDs
AMAZON_ASSOCIATE_TAG=findivo-20
# Product Advertising API (apply separately after Associates approval)
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=findivo-20

# --- Google OAuth (console.cloud.google.com) ---
# Create OAuth 2.0 Client ID for Web Application
GOOGLE_CLIENT_ID=778081610191-rp1vvc0sn1o1jhydeb26tcq4iqp8ebvd.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-3oqqGbcx2E5cxS-q1XiZD3C2UdD

# --- App ---
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# --- Optional: OpenAI (add in Step 3 when building AI search) ---
# OPENAI_API_KEY=sk-...
